ehthumbs.db
Desktop.ini
.DS_Store

# IDE
.vs/
.idea/
.vscode/
*.sln.iml

# Secrets - never commit
*.pfx
*.snk
*.env
*.env.*
security-audit-*.md

# SQLite databases (local audit log, snapshots)
*.db
*.db-shm
*.db-wal

# Logs
logs/
*.err

