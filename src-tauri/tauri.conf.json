{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSPanel",
  "version": "0.6.0",
  "identifier": "com.mibu.dspanel",
  "build": {
    "beforeDevCommand": "npx pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DSPanel",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
