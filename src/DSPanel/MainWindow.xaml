<Window x:Class="DSPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DSPanel.Converters"
        xmlns:models="clr-namespace:DSPanel.Models"
        Title="{Binding Title}"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushSurfaceBackground}">

  <Window.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    <converters:PermissionLevelToColorConverter x:Key="PermissionToColor"/>

    <CollectionViewSource x:Key="GroupedSidebarItems" Source="{Binding SidebarItems}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Category"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </Window.Resources>

  <Window.InputBindings>
    <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTabKey}"/>
  </Window.InputBindings>

  <Grid>
    <Grid.ColumnDefinitions>
      <!-- Sidebar -->
      <ColumnDefinition Width="Auto"/>
      <!-- Content -->
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <!-- Status bar -->
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ==================== SIDEBAR ==================== -->
    <Border Grid.Column="0" Grid.Row="0"
            Background="{DynamicResource BrushSurfaceCard}"
            BorderBrush="{DynamicResource BrushBorderSubtle}"
            BorderThickness="0,0,1,0">

      <Grid>
        <Grid.RowDefinitions>
          <!-- Header with hamburger -->
          <RowDefinition Height="Auto"/>
          <!-- Nav items -->
          <RowDefinition Height="*"/>
          <!-- Bottom actions -->
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sidebar header -->
        <Border Grid.Row="0" Padding="8,12">
          <DockPanel>
            <Button DockPanel.Dock="Left"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding ToggleSidebarCommand}"
                    ToolTip="Toggle sidebar"
                    Width="36" Height="36">
              <Path Data="{StaticResource IconMenu}"
                    Width="20" Height="20"
                    Stretch="Uniform"
                    Fill="{DynamicResource BrushTextPrimary}"/>
            </Button>
            <TextBlock Text="DSPanel"
                       Style="{StaticResource Heading4}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
          </DockPanel>
        </Border>

        <!-- Navigation items grouped by category -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedSidebarItems}}">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               Style="{StaticResource Caption}"
                               FontWeight="SemiBold"
                               Margin="16,16,16,4"
                               Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type models:SidebarItem}">
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Key}"
                        HorizontalContentAlignment="Left"
                        Padding="12,10"
                        Margin="4,1"
                        ToolTip="{Binding Label}">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="{Binding IconGeometryKey, Converter={x:Static converters:GeometryResourceConverter.Instance}}"
                          Width="20" Height="20"
                          Stretch="Uniform"
                          Fill="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock Text="{Binding Label}"
                               Style="{StaticResource Body}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Bottom sidebar actions -->
        <StackPanel Grid.Row="2" Margin="4,4,4,8">
          <Button Style="{StaticResource GhostButton}"
                  Command="{Binding ToggleThemeCommand}"
                  HorizontalContentAlignment="Left"
                  Padding="12,10"
                  Margin="4,1"
                  ToolTip="Toggle theme">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconTheme}"
                    Width="20" Height="20"
                    Stretch="Uniform"
                    Fill="{DynamicResource BrushTextSecondary}"/>
              <TextBlock Text="Toggle theme"
                         Style="{StaticResource Body}"
                         VerticalAlignment="Center"
                         Margin="12,0,0,0"
                         Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ==================== CONTENT AREA ==================== -->
    <Grid Grid.Column="1" Grid.Row="0">
      <!-- Placeholder shown when no tabs are open -->
      <TextBlock Text="Select a module from the sidebar to get started."
                 Foreground="{DynamicResource BrushTextSecondary}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontFamily="Segoe UI"
                 FontSize="16">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <!-- Tab control -->
      <TabControl ItemsSource="{Binding Tabs}"
                  SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                  Background="{DynamicResource BrushSurfaceBackground}"
                  BorderThickness="0"
                  Padding="0">
        <TabControl.Style>
          <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TabControl.Style>
        <TabControl.ItemTemplate>
          <DataTemplate DataType="{x:Type models:TabItem}">
            <StackPanel Orientation="Horizontal" Margin="4,2">
              <TextBlock Text="{Binding Title}"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource BrushTextPrimary}"
                         FontSize="13"/>
              <Button Style="{StaticResource GhostButton}"
                      Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding Key}"
                      Visibility="{Binding CanClose, Converter={StaticResource BoolToVisibility}}"
                      ToolTip="Close tab"
                      Padding="4,2"
                      Margin="6,0,0,0"
                      VerticalAlignment="Center">
                <Path Data="{StaticResource IconClose}"
                      Width="12" Height="12"
                      Stretch="Uniform"
                      Fill="{DynamicResource BrushTextSecondary}"/>
              </Button>
            </StackPanel>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate DataType="{x:Type models:TabItem}">
            <Border Padding="24" Background="{DynamicResource BrushSurfaceBackground}">
              <ContentPresenter Content="{Binding Content}"/>
            </Border>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </Grid>

    <!-- ==================== STATUS BAR ==================== -->
    <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
            Background="{DynamicResource BrushSurfaceCard}"
            BorderBrush="{DynamicResource BrushBorderSubtle}"
            BorderThickness="0,1,0,0"
            Padding="12,6">
      <DockPanel>
        <!-- Right side: permission badge -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{Binding PermissionLevel, Converter={StaticResource PermissionToColor}}"
                  CornerRadius="{StaticResource BorderRadiusSm}"
                  Padding="8,3">
            <TextBlock Text="{Binding PermissionLevel}"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="SemiBold"/>
          </Border>
        </StackPanel>

        <!-- Left side: connection status, domain, DC -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Connection indicator dot -->
          <Ellipse Width="8" Height="8" Margin="0,0,8,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="{DynamicResource BrushError}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- Domain name -->
          <TextBlock Text="{Binding DomainName}"
                     Style="{StaticResource Caption}"
                     Margin="0,0,16,0"/>

          <!-- Connected DC -->
          <TextBlock Style="{StaticResource Caption}">
            <Run Text="DC: "/>
            <Run Text="{Binding ConnectedDc, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>
