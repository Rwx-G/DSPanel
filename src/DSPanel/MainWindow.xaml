<Window x:Class="DSPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DSPanel.Converters"
        xmlns:models="clr-namespace:DSPanel.Models"
        Title="{Binding Title}"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushSurfaceBackground}">

  <Window.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    <converters:PermissionLevelToColorConverter x:Key="PermissionToColor"/>
    <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibility"/>

    <CollectionViewSource x:Key="GroupedSidebarItems" Source="{Binding SidebarItems}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Category"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </Window.Resources>

  <Window.InputBindings>
    <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTabKey}"/>
  </Window.InputBindings>

  <Grid>
    <Grid.ColumnDefinitions>
      <!-- Sidebar -->
      <ColumnDefinition Width="Auto"/>
      <!-- Content -->
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <!-- Status bar -->
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ==================== SIDEBAR ==================== -->
    <Border Grid.Column="0" Grid.Row="0"
            Background="{DynamicResource BrushSurfaceCard}"
            BorderBrush="{DynamicResource BrushBorderSubtle}"
            BorderThickness="0,0,1,0">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Width" Value="220"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
              <Setter Property="Width" Value="52"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sidebar header: hamburger button -->
        <Button Grid.Row="0"
                Style="{StaticResource GhostButton}"
                Command="{Binding ToggleSidebarCommand}"
                AutomationProperties.Name="Toggle sidebar"
                ToolTip="Toggle sidebar"
                HorizontalContentAlignment="Left"
                Padding="0"
                Height="48" Margin="6,8,6,4">
          <StackPanel Orientation="Horizontal">
            <Path Width="20" Height="20" Stretch="Uniform"
                  Fill="{DynamicResource BrushTextPrimary}"
                  Margin="10,0">
              <Path.Style>
                <Style TargetType="Path">
                  <Setter Property="Data" Value="{StaticResource IconChevronLeft}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                      <Setter Property="Data" Value="{StaticResource IconMenu}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Path.Style>
            </Path>
            <TextBlock Text="DSPanel"
                       Style="{StaticResource Heading4}"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
          </StackPanel>
        </Button>

        <!-- Navigation items -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedSidebarItems}}">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.ContainerStyle>
                  <Style TargetType="GroupItem">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="GroupItem">
                          <StackPanel>
                            <ContentPresenter/>
                            <ItemsPresenter/>
                          </StackPanel>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </GroupStyle.ContainerStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <Separator Background="{DynamicResource BrushBorderDefault}" Margin="12,8,12,4"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemContainerStyle>
              <Style TargetType="ContentPresenter">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type models:SidebarItem}">
                <Grid Margin="6,1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <!-- Active indicator bar -->
                  <Border Grid.Column="0"
                          Background="{DynamicResource BrushPrimary}"
                          CornerRadius="1.5"
                          Margin="0,4">
                    <Border.Visibility>
                      <MultiBinding Converter="{StaticResource EqualityToVisibility}">
                        <Binding Path="Key"/>
                        <Binding Path="DataContext.ActiveTabKey" RelativeSource="{RelativeSource AncestorType=Window}"/>
                      </MultiBinding>
                    </Border.Visibility>
                  </Border>

                  <Button Grid.Column="1"
                          Style="{StaticResource GhostButton}"
                          Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding Key}"
                          AutomationProperties.Name="{Binding Label}"
                          HorizontalContentAlignment="Left"
                          Padding="0"
                          Height="40"
                          ToolTip="{Binding Label}">
                    <StackPanel Orientation="Horizontal">
                      <Path Data="{Binding IconGeometryKey, Converter={x:Static converters:GeometryResourceConverter.Instance}}"
                            Width="20" Height="20"
                            Stretch="Uniform"
                            Fill="{DynamicResource BrushTextSecondary}"
                            Margin="10,0"/>
                      <TextBlock Text="{Binding Label}"
                                 Style="{StaticResource Body}"
                                 VerticalAlignment="Center"
                                 Margin="10,0,0,0"
                                 Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Bottom sidebar actions -->
        <StackPanel Grid.Row="2" Margin="0,4,0,8">
          <Separator Background="{DynamicResource BrushBorderDefault}" Margin="12,0,12,4"/>
          <Button Style="{StaticResource GhostButton}"
                  Command="{Binding ToggleThemeCommand}"
                  AutomationProperties.Name="Toggle theme"
                  HorizontalContentAlignment="Left"
                  Padding="0"
                  Height="40" Margin="6,1"
                  ToolTip="Toggle theme">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconTheme}"
                    Width="20" Height="20"
                    Stretch="Uniform"
                    Fill="{DynamicResource BrushTextSecondary}"
                    Margin="10,0"/>
              <TextBlock Text="Toggle theme"
                         Style="{StaticResource Body}"
                         VerticalAlignment="Center"
                         Margin="10,0,0,0"
                         Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ==================== CONTENT AREA ==================== -->
    <Grid Grid.Column="1" Grid.Row="0">
      <!-- Default status dashboard when no tabs are open -->
      <Border Padding="32">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel VerticalAlignment="Top" MaxWidth="600" HorizontalAlignment="Left">
          <TextBlock Text="Status" Style="{StaticResource Heading1}" Margin="0,0,0,24"/>

          <!-- Connection card -->
          <Border Background="{DynamicResource BrushSurfaceCard}"
                  CornerRadius="{StaticResource BorderRadiusMd}"
                  Padding="20" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="Connection" Style="{StaticResource Heading4}" Margin="0,0,0,12"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                  <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource BrushError}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsConnected}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                  <TextBlock>
                    <TextBlock.Style>
                      <Style TargetType="TextBlock" BasedOn="{StaticResource Body}">
                        <Setter Property="Text" Value="Disconnected"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsConnected}" Value="True">
                            <Setter Property="Text" Value="Connected"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Domain" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DomainName}" Style="{StaticResource Body}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Domain Controller" Style="{StaticResource Caption}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConnectedDc}" Style="{StaticResource Body}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Account card -->
          <Border Background="{DynamicResource BrushSurfaceCard}"
                  CornerRadius="{StaticResource BorderRadiusMd}"
                  Padding="20" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="Account" Style="{StaticResource Heading4}" Margin="0,0,0,12"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Permission" Style="{StaticResource Caption}"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                  <Border Background="{Binding PermissionLevel, Converter={StaticResource PermissionToColor}}"
                          CornerRadius="{StaticResource BorderRadiusSm}"
                          Padding="8,3">
                    <TextBlock Text="{Binding PermissionLevel}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                  </Border>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Tab control -->
      <TabControl ItemsSource="{Binding Tabs}"
                  SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabControl.Style>
          <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TabControl.Style>
        <TabControl.ItemTemplate>
          <DataTemplate DataType="{x:Type models:TabItem}">
            <StackPanel Orientation="Horizontal">
              <!-- Hidden bold text to reserve max width and prevent layout shift -->
              <Grid>
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Visibility="Hidden"/>
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
              </Grid>
              <Button Style="{StaticResource CloseButton}"
                      Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding Key}"
                      Visibility="{Binding CanClose, Converter={StaticResource BoolToVisibility}}"
                      AutomationProperties.Name="Close tab"
                      ToolTip="Close tab"
                      Width="24" Height="24"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center">
                <Path Data="{StaticResource IconClose}"
                      Width="10" Height="10"
                      Stretch="Uniform"
                      Fill="{DynamicResource BrushTextSecondary}"/>
              </Button>
            </StackPanel>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate DataType="{x:Type models:TabItem}">
            <Border Padding="24" Background="{DynamicResource BrushSurfaceBackground}">
              <ContentPresenter Content="{Binding Content}"/>
            </Border>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </Grid>

    <!-- ==================== STATUS BAR ==================== -->
    <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
            Background="{DynamicResource BrushSurfaceCard}"
            BorderBrush="{DynamicResource BrushBorderSubtle}"
            BorderThickness="0,1,0,0"
            Padding="12,6">
      <DockPanel>
        <!-- Right side: permission badge -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{Binding PermissionLevel, Converter={StaticResource PermissionToColor}}"
                  CornerRadius="{StaticResource BorderRadiusSm}"
                  Padding="8,3">
            <TextBlock Text="{Binding PermissionLevel}"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="SemiBold"/>
          </Border>
        </StackPanel>

        <!-- Left side: connection status, domain, DC -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Connection indicator dot -->
          <Ellipse Width="8" Height="8" Margin="0,0,8,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="{DynamicResource BrushError}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- Domain name -->
          <TextBlock Text="{Binding DomainName}"
                     Style="{StaticResource Caption}"
                     Margin="0,0,16,0"/>

          <!-- Connected DC -->
          <TextBlock Style="{StaticResource Caption}">
            <Run Text="DC: "/>
            <Run Text="{Binding ConnectedDc, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>
