<UserControl x:Class="DSPanel.Views.Controls.Avatar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid x:Name="PART_Root" Width="32" Height="32">
    <!-- Initials fallback -->
    <Border x:Name="PART_InitialsBorder"
            CornerRadius="16"
            Width="32" Height="32">
      <TextBlock x:Name="PART_Initials"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="13"
                 FontWeight="SemiBold"
                 FontFamily="Segoe UI"
                 Foreground="White"/>
    </Border>
    <!-- Image overlay -->
    <Border x:Name="PART_ImageBorder"
            CornerRadius="16"
            Width="32" Height="32"
            Visibility="Collapsed">
      <Border.Background>
        <ImageBrush x:Name="PART_ImageBrush" Stretch="UniformToFill"/>
      </Border.Background>
    </Border>
  </Grid>
</UserControl>
