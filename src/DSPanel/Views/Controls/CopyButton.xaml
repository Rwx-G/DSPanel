<UserControl x:Class="DSPanel.Views.Controls.CopyButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Button x:Name="PART_Button"
          Style="{StaticResource GhostButton}"
          Click="OnCopyClick"
          ToolTip="Copy to clipboard"
          Padding="4">
    <Grid>
      <Path x:Name="PART_CopyIcon"
            Data="{StaticResource IconCopy}"
            Fill="{DynamicResource BrushTextSecondary}"
            Width="14" Height="14"
            Stretch="Uniform"/>
      <Path x:Name="PART_CheckIcon"
            Data="{StaticResource IconCheck}"
            Fill="{DynamicResource BrushSuccess}"
            Width="14" Height="14"
            Stretch="Uniform"
            Visibility="Collapsed"/>
    </Grid>
  </Button>
</UserControl>
