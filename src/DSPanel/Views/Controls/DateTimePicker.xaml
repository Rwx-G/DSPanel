<UserControl x:Class="DSPanel.Views.Controls.DateTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Background="{DynamicResource BrushSurfaceCard}"
          Padding="8">
    <StackPanel Orientation="Horizontal">
      <!-- Date picker -->
      <DatePicker x:Name="PART_DatePicker"
                  SelectedDateChanged="OnDateChanged"
                  VerticalAlignment="Center"
                  BorderThickness="0"
                  Background="Transparent"/>

      <TextBlock Text="at"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource BrushTextSecondary}"
                 Margin="8,0"/>

      <!-- Hour spinner -->
      <Border BorderBrush="{DynamicResource BrushBorderDefault}"
              BorderThickness="1"
              CornerRadius="{StaticResource BorderRadiusSm}"
              Padding="4,2">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBox x:Name="PART_HourBox"
                   Text="00"
                   Width="36"
                   TextAlignment="Center"
                   BorderThickness="0"
                   Background="Transparent"
                   MaxLength="2"
                   TextChanged="OnTimeTextChanged"
                   VerticalAlignment="Center"/>
          <TextBlock Text=":" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
          <TextBox x:Name="PART_MinuteBox"
                   Text="00"
                   Width="36"
                   TextAlignment="Center"
                   BorderThickness="0"
                   Background="Transparent"
                   MaxLength="2"
                   TextChanged="OnTimeTextChanged"
                   VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Up/Down buttons -->
      <StackPanel Margin="4,0,0,0" VerticalAlignment="Center">
        <Button Style="{StaticResource GhostButton}"
                Content="&#x25B2;" FontSize="8" Padding="4,1"
                Click="OnHourUp"/>
        <Button Style="{StaticResource GhostButton}"
                Content="&#x25BC;" FontSize="8" Padding="4,1"
                Click="OnHourDown"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
