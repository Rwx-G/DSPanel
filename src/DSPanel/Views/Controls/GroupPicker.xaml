<UserControl x:Class="DSPanel.Views.Controls.GroupPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DSPanel.Views.Controls">
  <Border BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Background="{DynamicResource BrushSurfaceCard}"
          Padding="12">
    <StackPanel>
      <!-- Selected groups as chips -->
      <WrapPanel x:Name="PART_SelectedChips" Margin="0,0,0,8"/>

      <!-- Search box -->
      <TextBox x:Name="PART_SearchBox"
               TextChanged="OnSearchTextChanged"
               Tag="Search groups..."/>

      <!-- Results list with checkboxes -->
      <ListBox x:Name="PART_ResultsList"
               MaxHeight="200"
               Margin="0,8,0,0"
               BorderThickness="0"
               Background="Transparent"
               Visibility="Collapsed">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding DisplayName}"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      Checked="OnGroupChecked"
                      Unchecked="OnGroupUnchecked"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>
  </Border>
</UserControl>
