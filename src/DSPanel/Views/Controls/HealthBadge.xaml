<UserControl x:Class="DSPanel.Views.Controls.HealthBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DSPanel.Converters">
  <UserControl.Resources>
    <converters:HealthLevelToColorConverter x:Key="HealthLevelToColor"/>
  </UserControl.Resources>

  <Border x:Name="PART_Border"
          CornerRadius="8"
          Padding="8,3"
          VerticalAlignment="Center"
          HorizontalAlignment="Left">
    <Border.ToolTip>
      <ToolTip x:Name="PART_ToolTip">
        <ItemsControl x:Name="PART_FlagsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Margin="0,1">
                <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text=" - "/>
                <Run Text="{Binding Description, Mode=OneWay}"/>
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ToolTip>
    </Border.ToolTip>

    <StackPanel Orientation="Horizontal">
      <!-- Colored dot -->
      <Ellipse x:Name="PART_Dot"
               Width="8" Height="8"
               VerticalAlignment="Center"
               Margin="0,0,6,0"/>

      <!-- Status text -->
      <TextBlock x:Name="PART_Text"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center"/>
    </StackPanel>
  </Border>
</UserControl>
