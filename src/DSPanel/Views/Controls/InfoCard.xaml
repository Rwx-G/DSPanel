<UserControl x:Class="DSPanel.Views.Controls.InfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{DynamicResource BrushSurfaceCard}"
          BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Padding="0">
    <StackPanel>
      <!-- Header -->
      <Button x:Name="PART_HeaderButton"
              Click="OnHeaderClick"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
              HorizontalContentAlignment="Stretch"
              Padding="16,12">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border x:Name="headerBorder"
                    Background="Transparent"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="{StaticResource BorderRadiusMd}">
              <ContentPresenter HorizontalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="headerBorder" Property="Background" Value="{DynamicResource BrushRowHover}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <!-- Icon -->
          <Path x:Name="PART_Icon"
                Grid.Column="0"
                Width="16" Height="16"
                Stretch="Uniform"
                Fill="{DynamicResource BrushTextSecondary}"
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                Visibility="Collapsed"/>
          <!-- Header text -->
          <TextBlock x:Name="PART_HeaderText"
                     Grid.Column="1"
                     FontSize="14"
                     FontWeight="SemiBold"
                     FontFamily="Segoe UI"
                     Foreground="{DynamicResource BrushTextPrimary}"
                     VerticalAlignment="Center"/>
          <!-- Chevron -->
          <Path x:Name="PART_Chevron"
                Grid.Column="2"
                Data="{StaticResource IconChevronDown}"
                Width="12" Height="12"
                Stretch="Uniform"
                Fill="{DynamicResource BrushTextSecondary}"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
              <RotateTransform x:Name="PART_ChevronRotation" Angle="0"/>
            </Path.RenderTransform>
          </Path>
        </Grid>
      </Button>
      <!-- Content -->
      <Border x:Name="PART_ContentBorder"
              Padding="16,8,16,16">
        <ContentPresenter x:Name="PART_Content"/>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
