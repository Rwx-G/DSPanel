<UserControl x:Class="DSPanel.Views.Controls.OUPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DSPanel.Models">
  <Border BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Background="{DynamicResource BrushSurfaceCard}"
          MaxHeight="300">
    <Grid>
      <TreeView x:Name="PART_Tree"
                BorderThickness="0"
                Background="Transparent"
                SelectedItemChanged="OnSelectedItemChanged">
        <TreeView.ItemTemplate>
          <HierarchicalDataTemplate DataType="{x:Type models:OrganizationalUnit}"
                                     ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconDomain}"
                    Width="14" Height="14"
                    Stretch="Uniform"
                    Fill="{DynamicResource BrushTextSecondary}"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"/>
              <TextBlock Text="{Binding Name}"
                         Foreground="{DynamicResource BrushTextPrimary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>
      <!-- Empty state -->
      <TextBlock x:Name="PART_Empty"
                 Text="No organizational units loaded"
                 Style="{StaticResource Caption}"
                 Foreground="{DynamicResource BrushTextDisabled}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="16"
                 Visibility="Collapsed"/>
    </Grid>
  </Border>
</UserControl>
