<UserControl x:Class="DSPanel.Views.Controls.PropertyGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DSPanel.Views.Controls">
  <ItemsControl x:Name="PART_ItemsControl"
                ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=UserControl}}">
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Label -->
          <TextBlock Grid.Column="0"
                     Text="{Binding Label}"
                     Style="{StaticResource Caption}"
                     VerticalAlignment="Center"
                     Padding="0,6"/>

          <!-- Value -->
          <TextBlock Grid.Column="1"
                     Text="{Binding Value}"
                     Style="{StaticResource Body}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap"
                     Padding="8,6,0,6"/>

          <!-- Copy button (visible when IsCopyable is true) -->
          <controls:CopyButton Grid.Column="2"
                               TextToCopy="{Binding Value}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0">
            <controls:CopyButton.Style>
              <Style TargetType="controls:CopyButton">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsCopyable}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </controls:CopyButton.Style>
          </controls:CopyButton>
        </Grid>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
