<UserControl x:Class="DSPanel.Views.Controls.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DSPanel.Converters">
  <UserControl.Resources>
    <converters:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility"/>
  </UserControl.Resources>

  <Border Background="{DynamicResource BrushSurfaceCard}"
          BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Padding="8,0">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <!-- Search icon -->
      <Path Grid.Column="0"
            Data="{StaticResource IconSearch}"
            Fill="{DynamicResource BrushTextSecondary}"
            Width="16" Height="16"
            Stretch="Uniform"
            VerticalAlignment="Center"
            Margin="0,0,8,0"/>

      <!-- Search text box -->
      <TextBox x:Name="PART_SearchBox"
               Grid.Column="1"
               Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
               Background="Transparent"
               BorderThickness="0"
               VerticalAlignment="Center"
               FontSize="14"
               Padding="0,6"/>

      <!-- Placeholder text -->
      <TextBlock Grid.Column="1"
                 Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Foreground="{DynamicResource BrushTextDisabled}"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 FontSize="14"
                 Padding="0,6">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <!-- Clear button -->
      <Button Grid.Column="2"
              Style="{StaticResource GhostButton}"
              Click="OnClearClick"
              VerticalAlignment="Center"
              Padding="4"
              Margin="4,0,0,0"
              Visibility="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NonEmptyStringToVisibility}}">
        <Path Data="{StaticResource IconClose}"
              Fill="{DynamicResource BrushTextSecondary}"
              Width="12" Height="12"
              Stretch="Uniform"/>
      </Button>
    </Grid>
  </Border>
</UserControl>
