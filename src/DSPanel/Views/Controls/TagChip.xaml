<UserControl x:Class="DSPanel.Views.Controls.TagChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border CornerRadius="{StaticResource BorderRadiusLg}"
          Background="{DynamicResource BrushRowAlternate}"
          Padding="10,4"
          VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal">
      <TextBlock x:Name="PART_Text"
                 FontSize="12"
                 FontFamily="Segoe UI"
                 Foreground="{DynamicResource BrushTextPrimary}"
                 VerticalAlignment="Center"/>
      <Button x:Name="PART_RemoveButton"
              Style="{StaticResource CloseButton}"
              Width="16" Height="16"
              Margin="6,0,0,0"
              Click="OnRemoveClick"
              ToolTip="Remove"
              Visibility="Collapsed">
        <Path Data="{StaticResource IconClose}"
              Fill="{DynamicResource BrushTextSecondary}"
              Width="8" Height="8"
              Stretch="Uniform"/>
      </Button>
    </StackPanel>
  </Border>
</UserControl>
