<UserControl x:Class="DSPanel.Views.Controls.ValidationSummary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border x:Name="PART_Border"
          Background="{DynamicResource BrushErrorLight}"
          BorderBrush="{DynamicResource BrushError}"
          BorderThickness="1"
          CornerRadius="{StaticResource BorderRadiusMd}"
          Padding="12"
          Visibility="Collapsed">
    <StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
        <Path Data="{StaticResource IconError}"
              Width="16" Height="16"
              Stretch="Uniform"
              Fill="{DynamicResource BrushError}"
              Margin="0,0,8,0"
              VerticalAlignment="Center"/>
        <TextBlock Text="Validation Errors"
                   FontWeight="SemiBold"
                   FontSize="13"
                   Foreground="{DynamicResource BrushError}"
                   VerticalAlignment="Center"/>
      </StackPanel>
      <ItemsControl x:Name="PART_ErrorList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"
                       Foreground="{DynamicResource BrushError}"
                       FontSize="12"
                       Margin="24,2,0,2"
                       TextWrapping="Wrap"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
