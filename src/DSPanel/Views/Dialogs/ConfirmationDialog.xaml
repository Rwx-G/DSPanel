<Window x:Class="DSPanel.Views.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="440"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
  </Window.Resources>

  <Border Background="{DynamicResource BrushSurfaceCard}"
          CornerRadius="8"
          BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          Margin="8">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3" Direction="270"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" Padding="24,20,24,0">
        <StackPanel Orientation="Horizontal">
          <Path x:Name="IconPath"
                Width="24" Height="24"
                Stretch="Uniform"
                Margin="0,0,12,0"
                VerticalAlignment="Center"/>
          <TextBlock x:Name="TitleText"
                     Style="{StaticResource Heading4}"
                     Text="{Binding Title}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Message -->
      <Border Grid.Row="1" Padding="24,16">
        <TextBlock Text="{Binding Message}"
                   Style="{StaticResource Body}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource BrushTextSecondary}"/>
      </Border>

      <!-- Details (collapsible) -->
      <Border Grid.Row="2" Padding="24,0,24,8"
              Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}">
        <Expander Header="Details">
          <Border Background="{DynamicResource BrushSurfaceBackground}"
                  CornerRadius="{StaticResource BorderRadiusMd}"
                  Padding="12,8"
                  Margin="0,8,0,0">
            <TextBlock Text="{Binding Details}"
                       Style="{StaticResource Caption}"
                       FontFamily="Cascadia Code, Consolas"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextSecondary}"/>
          </Border>
        </Expander>
      </Border>

      <!-- Buttons -->
      <Border Grid.Row="3" Padding="24,8,24,20">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource SecondaryButton}"
                  Content="Cancel"
                  MinWidth="80"
                  Margin="0,0,8,0"
                  IsCancel="True"
                  Click="OnCancelClick"/>
          <Button Style="{StaticResource PrimaryButton}"
                  Content="Confirm"
                  MinWidth="80"
                  IsDefault="True"
                  Click="OnConfirmClick"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
