<Window x:Class="DSPanel.Views.Dialogs.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="440"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

  <Border Background="{DynamicResource BrushSurfaceCard}"
          CornerRadius="8"
          BorderBrush="{DynamicResource BrushBorderDefault}"
          BorderThickness="1"
          Margin="8">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3" Direction="270"/>
    </Border.Effect>
    <StackPanel Margin="24,20">
      <!-- Title -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <Path x:Name="CompletionIcon"
              Width="24" Height="24"
              Stretch="Uniform"
              Margin="0,0,10,0"
              VerticalAlignment="Center"
              Visibility="Collapsed"/>
        <TextBlock x:Name="TitleText"
                   Text="Processing..."
                   Style="{StaticResource Heading4}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Status message -->
      <TextBlock x:Name="StatusText"
                 Text="Please wait..."
                 Style="{StaticResource Body}"
                 Foreground="{DynamicResource BrushTextSecondary}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,12"/>

      <!-- Progress bar -->
      <ProgressBar x:Name="ProgressBarControl"
                   Height="6"
                   IsIndeterminate="True"
                   Foreground="{DynamicResource BrushPrimary}"
                   Background="{DynamicResource BrushSurfaceBackground}"
                   Margin="0,0,0,4"/>

      <!-- Percentage label -->
      <TextBlock x:Name="PercentageText"
                 Style="{StaticResource Caption}"
                 Foreground="{DynamicResource BrushTextSecondary}"
                 HorizontalAlignment="Right"
                 Visibility="Collapsed"
                 Margin="0,0,0,16"/>

      <!-- Cancel / Close button -->
      <Button x:Name="CancelButton"
              Style="{StaticResource SecondaryButton}"
              Content="Cancel"
              MinWidth="80"
              HorizontalAlignment="Right"
              Margin="0,8,0,0"
              Click="OnCancelClick"/>
    </StackPanel>
  </Border>
</Window>
