<UserControl x:Class="DSPanel.Views.Pages.ComputerLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DSPanel.Views.Controls"
             xmlns:converters="clr-namespace:DSPanel.Converters">
  <UserControl.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
  </UserControl.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Search bar -->
    <controls:SearchBar Grid.Row="0"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        SearchCommand="{Binding SearchCommand}"
                        PlaceholderText="Search computers by name or DNS host name..."
                        AutomationProperties.Name="Search computers"
                        Margin="0,0,0,12"/>

    <!-- Two-panel layout -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="350" MinWidth="250"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left panel: search results -->
      <Border Grid.Column="0"
              Background="{DynamicResource BrushSurfaceCard}"
              BorderBrush="{DynamicResource BrushBorderDefault}"
              BorderThickness="1"
              CornerRadius="{StaticResource BorderRadiusMd}">
        <Grid>
          <!-- Loading spinner -->
          <controls:LoadingSpinner IsActive="{Binding IsSearching}"
                                   Message="Searching..."/>

          <!-- Empty state -->
          <controls:EmptyState Message="No computers found. Try a different search query."
                               IconKey="IconComputer">
            <controls:EmptyState.Style>
              <Style TargetType="controls:EmptyState">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding SearchResults.Count}" Value="0"/>
                      <Condition Binding="{Binding IsSearching}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </controls:EmptyState.Style>
          </controls:EmptyState>

          <!-- Results list -->
          <ListBox ItemsSource="{Binding SearchResults}"
                   SelectedItem="{Binding SelectedComputer, Mode=TwoWay}"
                   VirtualizingStackPanel.IsVirtualizing="True"
                   VirtualizingStackPanel.VirtualizationMode="Recycling"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="8,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <!-- Computer name -->
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="{Binding Name}"
                             Style="{StaticResource Body}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- OS info -->
                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Text="{Binding OperatingSystem}"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             FontSize="12"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- Enabled/disabled indicator -->
                  <Ellipse Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                           Width="8" Height="8"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Enabled}" Value="False">
                            <Setter Property="Fill" Value="{DynamicResource BrushError}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="Transparent"/>

      <!-- Right panel: detail view -->
      <Border Grid.Column="2"
              Background="{DynamicResource BrushSurfaceCard}"
              BorderBrush="{DynamicResource BrushBorderDefault}"
              BorderThickness="1"
              CornerRadius="{StaticResource BorderRadiusMd}"
              Margin="6,0,0,0">
        <Grid>
          <!-- Empty state when no computer selected -->
          <controls:EmptyState Message="Select a computer to view details."
                               IconKey="IconComputer"
                               Visibility="{Binding HasSelectedComputer, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

          <!-- Computer detail panel -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding HasSelectedComputer, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="16">
              <!-- Header -->
              <TextBlock Text="{Binding SelectedComputer.Name}"
                         Style="{StaticResource Body}"
                         FontSize="20"
                         FontWeight="Bold"
                         Margin="0,0,0,4"/>
              <TextBlock Text="{Binding SelectedComputer.DnsHostName}"
                         Foreground="{DynamicResource BrushTextSecondary}"
                         FontSize="14"
                         Margin="0,0,0,16"/>

              <!-- Property grid -->
              <controls:PropertyGrid Items="{Binding DetailItems}"
                                     Margin="0,0,0,16"/>

              <!-- Network diagnostics -->
              <TextBlock Text="Network Diagnostics"
                         Style="{StaticResource Body}"
                         FontWeight="SemiBold"
                         FontSize="14"
                         Margin="0,8,0,8"/>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Ping"
                        Command="{Binding PingCommand}"
                        Padding="16,6"
                        Margin="0,0,8,0"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Content="DNS Resolve"
                        Command="{Binding DnsResolveCommand}"
                        Padding="16,6"/>
              </StackPanel>

              <!-- Ping result -->
              <TextBlock Text="{Binding PingResult}"
                         Style="{StaticResource Body}"
                         FontSize="12"
                         Foreground="{DynamicResource BrushTextSecondary}"
                         Margin="0,0,0,4"
                         Visibility="{Binding PingResult, Converter={StaticResource BoolToVisibility}}"
                         TextWrapping="Wrap"/>

              <!-- DNS result -->
              <TextBlock Text="{Binding DnsResult}"
                         Style="{StaticResource Body}"
                         FontSize="12"
                         Foreground="{DynamicResource BrushTextSecondary}"
                         Margin="0,0,0,4"
                         Visibility="{Binding DnsResult, Converter={StaticResource BoolToVisibility}}"
                         TextWrapping="Wrap"/>

              <!-- Groups section -->
              <TextBlock Text="Group Memberships"
                         Style="{StaticResource Body}"
                         FontWeight="SemiBold"
                         FontSize="14"
                         Margin="0,16,0,8"/>

              <ItemsControl ItemsSource="{Binding ComputerGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource BrushRowAlternate}"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,0,2">
                      <TextBlock Text="{Binding}"
                                 Style="{StaticResource Body}"
                                 FontSize="12"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
