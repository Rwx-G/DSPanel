<UserControl x:Class="DSPanel.Views.Pages.UserLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DSPanel.Views.Controls"
             xmlns:converters="clr-namespace:DSPanel.Converters">
  <UserControl.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
  </UserControl.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Search bar -->
    <controls:SearchBar Grid.Row="0"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        SearchCommand="{Binding SearchCommand}"
                        PlaceholderText="Search users by name, SAM account name, or email..."
                        AutomationProperties.Name="Search users"
                        Margin="0,0,0,12"/>

    <!-- Two-panel layout -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="350" MinWidth="250"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left panel: search results -->
      <Border Grid.Column="0"
              Background="{DynamicResource BrushSurfaceCard}"
              BorderBrush="{DynamicResource BrushBorderDefault}"
              BorderThickness="1"
              CornerRadius="{StaticResource BorderRadiusMd}">
        <Grid>
          <!-- Loading spinner -->
          <controls:LoadingSpinner IsActive="{Binding IsSearching}"
                                   Message="Searching..."/>

          <!-- Empty state -->
          <controls:EmptyState Message="No users found. Try a different search query."
                               IconKey="IconUser">
            <controls:EmptyState.Style>
              <Style TargetType="controls:EmptyState">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding SearchResults.Count}" Value="0"/>
                      <Condition Binding="{Binding IsSearching}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </controls:EmptyState.Style>
          </controls:EmptyState>

          <!-- Results list -->
          <ListBox ItemsSource="{Binding SearchResults}"
                   SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                   VirtualizingStackPanel.IsVirtualizing="True"
                   VirtualizingStackPanel.VirtualizationMode="Recycling"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="8,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <!-- Display name -->
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="{Binding DisplayName}"
                             Style="{StaticResource Body}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- SAM account name and department -->
                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             FontSize="12"
                             TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding SamAccountName, Mode=OneWay}"/>
                    <Run Text=" - " Foreground="{DynamicResource BrushTextDisabled}"/>
                    <Run Text="{Binding Department, Mode=OneWay}"/>
                  </TextBlock>

                  <!-- Enabled/disabled indicator -->
                  <Ellipse Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                           Width="8" Height="8"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Enabled}" Value="False">
                            <Setter Property="Fill" Value="{DynamicResource BrushError}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="Transparent"/>

      <!-- Right panel: detail view -->
      <Border Grid.Column="2"
              Background="{DynamicResource BrushSurfaceCard}"
              BorderBrush="{DynamicResource BrushBorderDefault}"
              BorderThickness="1"
              CornerRadius="{StaticResource BorderRadiusMd}"
              Margin="6,0,0,0">
        <Grid>
          <!-- Empty state when no user selected -->
          <controls:EmptyState Message="Select a user to view details."
                               IconKey="IconUser"
                               Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

          <!-- User detail panel -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="16">
              <!-- Header with name and health badge -->
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <TextBlock Text="{Binding SelectedUser.DisplayName}"
                             Style="{StaticResource Body}"
                             FontSize="20"
                             FontWeight="Bold"/>
                  <TextBlock Text="{Binding SelectedUser.SamAccountName}"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             FontSize="14"
                             Margin="0,2,0,0"/>
                </StackPanel>

                <controls:HealthBadge Grid.Column="1"
                                      HealthStatus="{Binding HealthStatus}"
                                      VerticalAlignment="Top"/>
              </Grid>

              <!-- Property grid -->
              <controls:PropertyGrid Items="{Binding DetailItems}"
                                     Margin="0,0,0,16"/>

              <!-- Groups section -->
              <TextBlock Text="Group Memberships"
                         Style="{StaticResource Body}"
                         FontWeight="SemiBold"
                         FontSize="14"
                         Margin="0,8,0,8"/>

              <ItemsControl ItemsSource="{Binding UserGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource BrushRowAlternate}"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,0,2">
                      <TextBlock Text="{Binding}"
                                 Style="{StaticResource Body}"
                                 FontSize="12"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
